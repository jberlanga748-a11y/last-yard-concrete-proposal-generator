VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Server-only. Do not prefix with VITE_ and do not expose this in frontend code.
OPENAI_API_KEY=server_only_openai_key_do_not_prefix_with_vite

# Server-only. Required for public customer portal token lookup when Supabase RLS blocks anonymous browser reads.
# Do not prefix with VITE_ and never expose this key in frontend code.
SUPABASE_SERVICE_ROLE_KEY=server_only_supabase_service_role_key_do_not_prefix_with_vite
